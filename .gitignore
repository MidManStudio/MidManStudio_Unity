# ── Rust ──────────────────────────────────────────────────────────────────────
rust_lib/**/target/

# ── Unity generated ───────────────────────────────────────────────────────────
# Using wildcards ensures these folders are ignored anywhere in the repo, 
# including inside PackageCreatorSandbox/
**/[Ll]ibrary/
**/[Tt]emp/
**/[Ll]ogs/
**/[Uu]serSettings/
**/[Oo]bj/
**/[Bb]uild/
**/[Bb]uilds/
**/.vs/
*.png
*.jpg
# ── Keep compiled native libs ─────────────────────────────────────────────────
!packages/**/Plugins/Native/**/*.dll
!packages/**/Plugins/Native/**/*.dylib
!packages/**/Plugins/Native/**/*.so
!packages/**/Plugins/Native/**/*.a

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
*.swp
